# ==========================================
# CRAG Agent: Environment Variables Template
# ==========================================

# 1. Google Gemini API (Required for the LLM)
# Get yours here: https://aistudio.google.com/
GOOGLE_API_KEY=your_gemini_api_key_here

# 2. Tavily Search API (Required for the Web Fallback)
# Get yours here: https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# 3. LangSmith Tracing (Optional but recommended for observability)
# Get yours here: https://smith.langchain.com/
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_PROJECT=crag-portfolio-project

# Add any other keys here

# 4. LlamaParse API Key (Optional but highly recommended for unstructured PDFs/Tables)
# Get yours here: https://cloud.llamaindex.ai/
LLAMA_CLOUD_API_KEY=your_llama_cloud_api_key_here
